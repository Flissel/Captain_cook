# Only required for the legacy API-key-backed prototype, never for `python main.py demo`.
OPENAI_API_KEY=
CAPTAIN_MODEL=gpt-5.6
CAPTAIN_TIMEZONE=Europe/Berlin

# Planning-only AgentFarm evaluation. Keep the source path local and uncommitted.
AGENTFARM_INPUT_PATH=
AGENTFARM_EVALUATION_MAX_COMPONENTS=1
AGENTFARM_EVALUATION_MAX_ROUNDS=3
AGENTFARM_EVALUATION_MAX_CALLS=8

# Captain and Minibook.
MINIBOOK_PUBLIC_URL=http://localhost:3457
MINIBOOK_BACKEND_URL=http://localhost:3456
MINIBOOK_API_KEY=
MINIBOOK_PROJECTION_API_KEY=

# Local delivery services.
MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025
MAILPIT_URL=http://localhost:8025
MAILPIT_SMTP_HOST=host.docker.internal
MARIADB_PORT=3306
MARIADB_DATABASE=captain_ledger
MARIADB_USER=captain
MARIADB_PASSWORD=
MARIADB_ROOT_PASSWORD=

# Captain Gateway. Keep tokens local; the default claim lease is 90 minutes.
LEDGER_DSN=
CAPTAIN_GATEWAY_TOKEN=
WORKER_GATEWAY_TOKEN=
CAPTAIN_GATEWAY_URL=http://127.0.0.1:8090
GATEWAY_APPROVAL_ENABLED=false
GATEWAY_PORT=8090
GATEWAY_CLAIM_TTL_SECONDS=5400

# Captain Cook uses the existing VibeMind n8n instance by default.
N8N_MODE=external
N8N_URL=http://localhost:15678
N8N_CONTAINER_URL=http://host.docker.internal:15678
N8N_MCP_URL=http://localhost:15678/mcp-server/http
N8N_MCP_TOKEN=

# Set N8N_MODE=captain-builder to opt into the isolated Captain-owned builder.
CAPTAIN_N8N_URL=http://localhost:5679
CAPTAIN_N8N_API_KEY=
CAPTAIN_N8N_MCP_TOKEN=
CAPTAIN_N8N_PORT=5679
CONTEXT7_API_KEY=
